EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_secret_here

STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# Vision Agent (Python service in vision-agent/) — Gemini Live voice
GOOGLE_API_KEY=your_google_api_key
# Optional alias (either works; GOOGLE_API_KEY is preferred)
# GEMINI_API_KEY=your_google_api_key
# Optional: override Live model (see vision-agent/README.md)
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
VISION_AGENT_URL=http://127.0.0.1:8000

# Optional: production API base URL for native clients (defaults to Expo dev server)
# EXPO_PUBLIC_API_URL=https://your-app.expo.app
